<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background_white"
    android:padding="10dp"
    android:gravity="center">

    <!-- Top info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/widget_location_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ঢাকা"
            android:textColor="#15803D"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_hijri_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="০৮ মহররম"
            android:textColor="#475569"
            android:textSize="9sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        android:layout_marginBottom="6dp"
        android:orientation="horizontal" />

    <!-- Main Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/widget_item_bg_white"
        android:padding="6dp">

        <TextView
            android:id="@+id/widget_sunrise_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="সূর্যোদয় (Sunrise)"
            android:textColor="#B45309"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_sunrise_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="০৫:১২ এএম"
            android:textColor="#1E293B"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Bottom Gregorian date -->
    <TextView
        android:id="@+id/widget_gregorian_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="23 June 2026"
        android:textColor="#64748B"
        android:textSize="9sp"
        android:layout_marginTop="4dp" />

</LinearLayout>
