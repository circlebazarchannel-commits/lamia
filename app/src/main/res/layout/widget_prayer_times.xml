<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="14dp">

    <!-- Header Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/widget_location_container">

            <TextView
                android:id="@+id/widget_gregorian_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tuesday, 23 June 2026"
                android:textColor="#E0F2FE"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_hijri_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08 Muharram, 1448 AH"
                android:textColor="#34D399"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Location display -->
        <LinearLayout
            android:id="@+id/widget_location_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_item_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/widget_location_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ঢাকা"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Divider Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.7dp"
        android:background="#30FFFFFF"
        android:layout_marginBottom="10dp" />

    <!-- Prayer Times Rows -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Fajr Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/widget_item_bg"
            android:padding="8dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/label_fajr"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ফজর (Fajr)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/time_fajr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="০৪:১২ এএম"
                android:textColor="#10B982"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dhuhr Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/widget_item_bg"
            android:padding="8dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/label_dhuhr"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="যোহর (Dhuhr)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/time_dhuhr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="১২:১৫ পিএম"
                android:textColor="#10B982"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Asr Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/widget_item_bg"
            android:padding="8dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/label_asr"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="আসর (Asr)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/time_asr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="০৪:৩০ পিএম"
                android:textColor="#10B982"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Maghrib Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/widget_item_bg"
            android:padding="8dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/label_maghrib"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="মাগরিব (Maghrib)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/time_maghrib"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="০৬:৪৫ পিএম"
                android:textColor="#10B982"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Isha Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/widget_item_bg"
            android:padding="8dp">

            <TextView
                android:id="@+id/label_isha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="এশা (Isha)"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/time_isha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="০৮:১৫ পিএম"
                android:textColor="#10B982"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
