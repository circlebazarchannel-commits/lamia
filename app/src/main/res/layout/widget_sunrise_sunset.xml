<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp"
    android:gravity="center">

    <!-- Top info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_location_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ঢাকা"
            android:textColor="#E0F2FE"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_hijri_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="০৮ মহররম, ১৪৪৮"
            android:textColor="#34D399"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.7dp"
        android:background="#30FFFFFF"
        android:layout_marginBottom="10dp" />

    <!-- Split Sunrise and Sunset Cards -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Sunrise Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_item_bg"
            android:padding="6dp"
            android:layout_marginEnd="5dp">

            <TextView
                android:id="@+id/widget_sunrise_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="সূর্যোদয় (Sunrise)"
                android:textColor="#FDBA74"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_sunrise_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="০৫:১২ এএম"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Sunset Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_item_bg"
            android:padding="6dp"
            android:layout_marginStart="5dp">

            <TextView
                android:id="@+id/widget_sunset_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="সূর্যাস্ত (Sunset)"
                android:textColor="#F87171"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_sunset_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="০৬:৪৫ পিএম"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Gregorian date -->
    <TextView
        android:id="@+id/widget_gregorian_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="23 June 2026"
        android:textColor="#9CA3AF"
        android:textSize="10sp"
        android:layout_marginTop="8dp" />

</LinearLayout>
