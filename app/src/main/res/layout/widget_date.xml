<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background_white"
    android:padding="10dp"
    android:gravity="center">

    <!-- Top info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/widget_location_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ঢাকা"
            android:textColor="#15803D"
            android:textSize="10sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_date_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="আজকের তারিখ"
            android:textColor="#475569"
            android:textSize="9sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        android:layout_marginBottom="6dp"
        android:orientation="horizontal" />

    <!-- Main Date Display Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/widget_item_bg_white"
        android:padding="6dp">

        <!-- Hijri Date (Main Spiritual Date) -->
        <TextView
            android:id="@+id/widget_hijri_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="০৮ মহররম, ১৪৪৮ হিজরি"
            android:textColor="#15803D"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            android:layout_marginVertical="4dp"
            android:orientation="horizontal" />

        <!-- Gregorian Date (English) -->
        <TextView
            android:id="@+id/widget_gregorian_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="২৩ জুন ২০২৬"
            android:textColor="#1E293B"
            android:textSize="11sp"
            android:textStyle="bold"
            android:gravity="center" />
    </LinearLayout>

</LinearLayout>
