<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp"
    android:gravity="center">

    <!-- Top info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/widget_location_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ঢাকা"
            android:textColor="#34D399"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_hijri_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="০৮ মহররম"
            android:textColor="#E0F2FE"
            android:textSize="10sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.7dp"
        android:background="#30FFFFFF"
        android:layout_marginBottom="8dp" />

    <!-- Main Countdown Display Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/widget_item_bg"
        android:padding="8dp">

        <!-- Next Prayer Name -->
        <TextView
            android:id="@+id/widget_next_prayer_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="পরবর্তী নামাজ"
            android:textColor="#93C5FD"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_next_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="যোহর (Dhuhr)"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="2dp" />

        <!-- Next Prayer Remaining Time -->
        <TextView
            android:id="@+id/widget_next_prayer_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="০২:১৫:৩০"
            android:textColor="#10B982"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Bottom Gregorian date -->
    <TextView
        android:id="@+id/widget_gregorian_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="23 June 2026"
        android:textColor="#9CA3AF"
        android:textSize="10sp"
        android:layout_marginTop="6dp" />

</LinearLayout>
